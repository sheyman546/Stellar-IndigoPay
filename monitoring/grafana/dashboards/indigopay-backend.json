  "panels": [
    {
      "type": "row",
      "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 1,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Request rate (req/s) by status",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(http_requests_total{service=\"stellar-indigopay-api\"}[1m]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (s)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"stellar-indigopay-api\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"stellar-indigopay-api\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"stellar-indigopay-api\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "In-flight requests",
      "id": 4,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(http_requests_in_flight{service=\"stellar-indigopay-api\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx ratio (5m)",
      "id": 5,
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"stellar-indigopay-api\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{service=\"stellar-indigopay-api\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "row",
      "title": "Rate Limiting",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false,
      "id": 30,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "429 rate (req/s) by endpoint",
      "id": 31,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (endpoint, method) (rate(indigopay_rate_limit_hits_total{service=\"stellar-indigopay-api\"}[1m]))",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "description": "Rate of HTTP 429 responses per second, broken down by endpoint and HTTP method."
    },
    {
      "type": "timeseries",
      "title": "429 ratio (% of all requests)",
      "id": 32,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(indigopay_rate_limit_hits_total{service=\"stellar-indigopay-api\"}[5m])) / clamp_min(sum(rate(http_requests_total{service=\"stellar-indigopay-api\"}[5m])), 1)",
          "legendFormat": "429 ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          }
        }
      },
      "description": "Proportion of all HTTP responses that were 429 over the last 5 minutes."
    },
    {
      "type": "timeseries",
      "title": "Token bucket remaining capacity",
      "id": 33,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "indigopay_rate_limit_remaining{service=\"stellar-indigopay-api\",strategy=\"token-bucket\"}",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "description": "Current token-bucket fill level per endpoint. Drops to 0 when clients burst past the refill rate."
    },
    {
      "type": "stat",
      "title": "Endpoints at capacity",
      "id": 34,
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(indigopay_rate_limit_remaining{service=\"stellar-indigopay-api\"} == 0)",
          "legendFormat": "exhausted endpoints",
          "refId": "A"
        },
        {
          "expr": "count(indigopay_rate_limit_remaining{service=\"stellar-indigopay-api\",strategy=\"sliding-window\"} == 0)",
          "legendFormat": "sliding-window exhausted",
          "refId": "B"
        },
        {
          "expr": "count(indigopay_rate_limit_remaining{service=\"stellar-indigopay-api\",strategy=\"token-bucket\"} == 0)",
          "legendFormat": "token-bucket exhausted",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "description": "Number of rate-limited endpoints currently at zero remaining capacity, broken down by strategy."
    },
    {
      "type": "stat",
      "title": "Token bucket remaining (min)",
      "id": 35,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "min by (endpoint) (indigopay_rate_limit_remaining{service=\"stellar-indigopay-api\",strategy=\"token-bucket\"})",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "description": "Minimum token-bucket remaining capacity per endpoint. 0 means that endpoint is fully exhausted."
    },
