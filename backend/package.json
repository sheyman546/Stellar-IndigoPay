{
  "name": "zendvo-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "tsc": "tsc --noEmit",
    "start": "node dist/server.js",
    "test": "jest",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:check": "ts-node -e \"require('./src/lib/db/migration-checker').checkMigrationStatus().then(s => console.log(s.message))\""
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/client": "^7.5.0",
    "@stellar/stellar-sdk": "^14.4.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "express": "^4.19.2",
    "jose": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.7",
    "nodemailer": "^7.0.12",
    "next": "16.1.2",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "stripe": "^20.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-plugin-jest": "^29.15.1",
    "jest": "^30.2.0",
    "jest-regex-util": "^30.0.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
