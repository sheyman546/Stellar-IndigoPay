PORT=4000
NODE_ENV=development
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
ALLOWED_ORIGINS=https://stellarindigopay.app,https://www.stellarindigopay.app,http://localhost:3000,http://127.0.0.1:3000
CONTRACT_ID=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/indigopay

# Redis — caching layer for project list and stats (60-second TTL)
# Omit or leave blank to run without Redis (cache is silently bypassed)
REDIS_URL=redis://localhost:6379

# Transactional email — get a free API key at https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Stellar-IndigoPay <updates@yourdomain.com>
APP_URL=http://localhost:3000

# JWT secret for admin authentication (generate with: openssl rand -hex 32)
JWT_SECRET=

# Admin login credentials (used by POST /api/admin/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Hourly purge of expired refresh tokens and blacklisted access-token jtis.
# Cron syntax; set to "disabled" to turn the job off.
BLACKLIST_CLEANUP_CRON=20 * * * *

# Anthropic Claude API — required for AI project summaries
ANTHROPIC_API_KEY=

# PostgreSQL connection pool tuning
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
# Must be < (readiness check timeout - statement_timeout) so /api/readyz
# is never blocked by a slow connection acquire.
DB_POOL_CONNECT_TIMEOUT=1000
# Per-statement timeout in ms (mitigates slow-query pool exhaustion).
# Pushed to Postgres as `SET statement_timeout` on each new client.
# MUST be shorter than the readiness check timeout (default 4s) so a slow
# query is cancelled before /api/readyz reports 503.
DB_STATEMENT_TIMEOUT_MS=3000

# Sentry tracing sample rate. 0 disables, 1 samples everything.
# Production default 0.1 (10% of transactions). Anything above 0.5 gets
# expensive. SENTRY_DSN must be set for events to be delivered.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Observability — Prometheus scrape endpoint at GET /metrics.
# Bearer token required to scrape. If unset, the endpoint is unauthenticated
# (intended for local dev only). In production, set to a long random string
# (openssl rand -hex 32) and wire the same value into the k8s Secret.
METRICS_ENABLED=true
METRICS_BEARER_TOKEN=

# Rate limiter (per-IP, 15-minute window). Defaults to 150 req / 15min.
RATE_LIMIT_MAX=150

# Graceful shutdown. After this many ms of drain, the process exits anyway.
# Keep this lower than the Kubernetes terminationGracePeriodSeconds.
SHUTDOWN_TIMEOUT_MS=30000

# Readiness probe behaviour. /api/readyz fails if any of these is true:
#   - the DB is unreachable (always)
#   - READINESS_REQUIRE_REDIS=true and Redis is down
#   - the process is in graceful-shutdown drain
READINESS_REQUIRE_REDIS=false
# Per-subsystem timeout for each readiness check (DB, Redis, Horizon).
# Must be > (DB_POOL_CONNECT_TIMEOUT + DB_STATEMENT_TIMEOUT_MS) so a
# slow DB can never block the probe past its own deadline. Default 4000.
READINESS_CHECK_TIMEOUT_MS=4000

# Verification Request admin notification (defaults to EMAIL_FROM)
# Used by /api/verification-requests to email admins on new submissions.
ADMIN_NOTIFICATION_EMAIL=

# Document upload backend for the /apply form.
#   local   – writes to ./uploads and serves them at GET /api/uploads/:key.
#   s3      – requires AWS_REGION/AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY/S3_BUCKET.
#   ipfs    – requires IPFS_API_URL (HTTP /api/v0/add endpoint).
# Unknown/missing-credential configurations silently fall back to "local".
STORAGE_BACKEND=local
UPLOAD_MAX_BYTES=10485760

# S3 (only used when STORAGE_BACKEND=s3)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_URL=

# IPFS — decentralised, content-addressed storage for verification documents.
# When either WEB3_STORAGE_API_KEY or IPFS_API_URL is set, supporting
# documents submitted via /api/verification-requests are pinned to IPFS
# and their CID + gateway URL stored alongside the local copy.
WEB3_STORAGE_API_KEY=           # web3.storage API token (takes precedence)
IPFS_API_URL=                   # IPFS node HTTP API (/api/v0/add) — Infura, Pinata cluster, or local daemon
IPFS_GATEWAY_URL=https://w3s.link
IPFS_FALLBACK_TO_LOCAL=true     # Fall back to local storage when IPFS upload fails
IPFS_TIMEOUT_MS=30000           # Upload / gateway fetch timeout
