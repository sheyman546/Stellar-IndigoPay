{
  "expo": {
    "name": "Stellar IndigoPay",
    "slug": "stellar-indigopay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#227239"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stellarindigopay.app",
      "associatedDomains": [
        "applinks:indigopay.example.com",
        "webcredentials:indigopay.example.com"
      ],
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["indigopay", "web+stellar"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#227239"
      },
      "package": "com.stellarindigopay.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "indigopay" },
            {
              "scheme": "web+stellar",
              "host": "pay",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "indigopay.example.com",
              "pathPrefix": "/project/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#227239",
          "sounds": []
        }
      ]
    ],
    "scheme": "indigopay"
  },
  "extra": {
    "scheme": "indigopay"
  }
}
