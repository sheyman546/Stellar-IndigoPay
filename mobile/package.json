{
  "name": "indigopay-mobile",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "expo-clipboard": "~6.0.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-svg": "^15.3.0",
    "@sentry/react-native": "^5.22.0",
    "@react-native-async-storage/async-storage": "^1.23.0",
    "@react-native-community/netinfo": "^11.3.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^7.17.6",
    "@stellar/stellar-sdk": "^12.0.0",
    "axios": "^1.7.0",
    "expo": "~57.0.0",
    "expo-camera": "~15.0.0",
    "expo-linking": "~6.3.0",
    "expo-local-authentication": "~14.0.0",
    "expo-modules-core": "^57.0.5",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~14.0.0",
    "expo-sharing": "~57.0.1",
    "expo-status-bar": "~1.12.0",
    "react": "18.2.0",
    "react-native": "0.74.1",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "4.25.2",
    "react-native-view-shot": "^3.8.0",
    "test-renderer": "^1.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.2.0",
    "typescript": "~5.3.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "babel-plugin-jest-hoist": "^29.6.3",
    "babel-preset-expo": "~13.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "react-test-renderer": "^18.2.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?/|@react-native/)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@stellar/.*)"
    ],
    "moduleNameMapper": {
      "^react-native/Libraries/BatchedBridge/NativeModules$": "<rootDir>/__mocks__/NativeModules.js",
      "^axios$": "<rootDir>/__mocks__/axios.js",
      "^expo-local-authentication$": "<rootDir>/__mocks__/expo-local-authentication.js",
      "^expo-secure-store$": "<rootDir>/__mocks__/expo-secure-store.js",
      "^expo-notifications$": "<rootDir>/__mocks__/expo-notifications.js",
      "^@react-native-community/netinfo$": "<rootDir>/__mocks__/@react-native-community/netinfo.js",
      "^react-native/Libraries/BatchedBridge/NativeModules$": "<rootDir>/__mocks__/NativeModules.js"
    }
  }
}
